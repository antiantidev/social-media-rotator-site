---
import OverlayLayout from "../layouts/OverlayLayout.astro";
import overlayScriptUrl from "../scripts/overlay.ts?url";
---

<OverlayLayout>
  <div class="overlay-stage">
    <div id="cardFrame" class="overlay-cardFrame">
      <div id="overlayLoader" class="overlay-loader" aria-hidden="true">
        <div class="overlay-loader__badge">
          <span class="overlay-loader__pulse"></span>
        </div>
        <div class="overlay-loader__copy">
          <span class="overlay-loader__eyebrow">Loading Overlay</span>
          <span class="overlay-loader__title">Made with &lt;3 For Streamer</span>
          <span class="overlay-loader__byline">by Nhat Linh Nguyen</span>
        </div>
      </div>
      <div id="overlayEmptyState" class="overlay-emptyState" hidden aria-hidden="true">
        <span class="overlay-emptyState__eyebrow">No active platforms</span>
        <span class="overlay-emptyState__title">
          Enable at least one social profile to resume the live overlay.
        </span>
        <span class="overlay-emptyState__body">
          The preview clears to this state whenever every row is turned off.
        </span>
      </div>
      <div id="card" class="overlay-card" style="visibility:hidden;opacity:0;">
        <div class="overlay-card__iconWrap">
          <span id="icon" class="overlay-card__iconGlyph" aria-hidden="true"></span>
        </div>

        <div class="overlay-copy">
          <span id="label" class="overlay-label"></span>
          <span id="text" class="overlay-text"></span>
        </div>

        <div id="ctaBox" class="overlay-cta overlay-cta--default">
          <img id="ctaIcon" alt="CTA icon" />
          <span id="ctaText" class="overlay-cta__text"></span>
        </div>
      </div>
    </div>
  </div>

  <script type="module" src={overlayScriptUrl}></script>
</OverlayLayout>
