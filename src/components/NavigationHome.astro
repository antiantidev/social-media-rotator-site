---
import { sitePath } from "../lib/site.ts";

const {
  title = "Social Media Rotator",
  eyebrow = "Monochrome control surface",
  subtitle = "Flat, light, and built for browser sources.",
  primaryLabel = "Settings",
  primaryHref = sitePath("settings/"),
  secondaryLabel = "Overlay",
  secondaryHref = sitePath("overlay/"),
} = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-[var(--line)] bg-white/80 backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
    <a href={sitePath("")} class="flex items-center gap-3">
      <span class="flex h-11 w-11 items-center justify-center rounded-2xl border border-[var(--line)] bg-white text-[var(--text)] shadow-sm">
        <i class="fas fa-rss text-base"></i>
      </span>
      <span class="leading-tight">
        <span class="eyebrow">{eyebrow}</span>
        <span class="mt-1 block text-base font-semibold tracking-[-0.03em] text-[var(--text)] sm:text-lg">
          {title}
        </span>
        <span class="mt-1 block text-sm text-[var(--text-muted)]">{subtitle}</span>
      </span>
    </a>

    <div class="flex items-center gap-2 overflow-x-auto pb-1 sm:pb-0">
      <a href={primaryHref} class="button-muted shrink-0 px-4 py-2.5 text-sm font-medium">
        {primaryLabel}
      </a>
      <a href={secondaryHref} class="button-primary shrink-0 px-4 py-2.5 text-sm font-semibold">
        {secondaryLabel}
      </a>
    </div>
  </div>
</header>
