---
import { sitePath } from "../lib/site.ts";
---

<section class="px-4 pb-16 pt-14 sm:pt-20 lg:pb-24 lg:pt-24">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-10 lg:grid-cols-[1.05fr_.95fr] lg:items-end">
      <div class="animate-fadeInUp">
        <span class="eyebrow">Light theme only</span>
        <h1 class="mt-6 max-w-3xl text-5xl font-semibold tracking-[-0.05em] text-[var(--text)] sm:text-6xl lg:text-[5.7rem]">
          Rotate your socials with a calm, monochrome control surface.
        </h1>
        <p class="hero-lead mt-6 max-w-2xl">
          Social Media Rotator turns stream overlay links into a browser source that is easy to configure, easy to share,
          and easy to read on top of any scene.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href={sitePath("settings/")} class="button-primary">
            <i class="fas fa-gear"></i>
            <span>Open settings</span>
          </a>
          <a href={sitePath("overlay/")} class="button-secondary">
            <i class="fas fa-tv"></i>
            <span>Preview overlay</span>
          </a>
        </div>

        <div class="mt-6 flex flex-wrap gap-2">
          <span class="status-pill"><i class="fas fa-circle text-[0.5rem] text-[var(--accent)]"></i> Monochrome UI</span>
          <span class="status-pill"><i class="fas fa-circle text-[0.5rem] text-[var(--accent-2)]"></i> Fast setup</span>
          <span class="status-pill"><i class="fas fa-circle text-[0.5rem] text-[var(--accent-3)]"></i> Shareable token</span>
        </div>
      </div>

      <div class="animate-fadeInUp lg:ml-auto" style="animation-delay: 120ms">
        <div class="section-surface overflow-hidden p-5 sm:p-6 lg:p-7">
          <div class="flex items-center justify-between gap-4 border-b border-[var(--line)] pb-5">
            <div>
              <p class="eyebrow">Preview board</p>
              <p class="mt-2 text-sm text-[var(--text-muted)]">One quiet card with enough hierarchy to trust at a glance.</p>
            </div>
            <span class="soft-note shrink-0">800 × 600</span>
          </div>

          <div class="mt-6 grid gap-4 lg:grid-cols-[1.05fr_.95fr]">
            <div class="surface-soft rounded-[1.5rem] p-5">
              <div class="flex items-start gap-3">
                <span class="step-index text-sm">1</span>
                <div>
                  <p class="text-2xl font-semibold tracking-[-0.04em] text-[var(--text)]">Social cards in motion</p>
                  <p class="mt-1 text-sm leading-6 text-[var(--text-muted)]">Readable, quiet, and premium without decoration.</p>
                </div>
              </div>
              <div class="mt-5 space-y-3">
                <div class="flex items-center gap-3 rounded-2xl border border-[var(--line)] bg-white px-4 py-3 shadow-sm">
                  <span class="flex h-10 w-10 items-center justify-center rounded-xl border border-[var(--line)] bg-[var(--bg-panel-soft)] text-[var(--text)]">
                    <i class="fab fa-tiktok text-lg"></i>
                  </span>
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-[var(--text)]">TikTok</p>
                    <p class="truncate text-sm text-[var(--text-muted)]">@nguyennhatlinh.official</p>
                  </div>
                  <span class="ml-auto rounded-full border border-[var(--line)] bg-[var(--bg-panel-soft)] px-3 py-1 font-mono text-[0.7rem] tracking-[0.16em] text-[var(--text-muted)]">Active</span>
                </div>
                <div class="flex items-center gap-3 rounded-2xl border border-[var(--line)] bg-white px-4 py-3 shadow-sm">
                  <span class="flex h-10 w-10 items-center justify-center rounded-xl border border-[var(--line)] bg-[var(--bg-panel-soft)] text-[var(--text)]">
                    <i class="fab fa-youtube text-lg"></i>
                  </span>
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-[var(--text)]">YouTube</p>
                    <p class="truncate text-sm text-[var(--text-muted)]">@chokernguyen</p>
                  </div>
                  <span class="ml-auto rounded-full border border-[var(--line)] bg-[var(--bg-panel-soft)] px-3 py-1 font-mono text-[0.7rem] tracking-[0.16em] text-[var(--text-muted)]">Rotating</span>
                </div>
              </div>
            </div>

            <div class="grid gap-3">
              <div class="surface-soft rounded-[1.35rem] p-4">
                <p class="text-[0.68rem] uppercase tracking-[0.2em] text-[var(--text-soft)]">Token</p>
                <p class="mt-2 text-sm text-[var(--text)]">URL-safe payload, copyable in one click.</p>
              </div>
              <div class="surface-soft rounded-[1.35rem] p-4">
                <p class="text-[0.68rem] uppercase tracking-[0.2em] text-[var(--text-soft)]">Timing</p>
                <p class="mt-2 text-sm text-[var(--text)]">Smooth in, calm hold, intentional exit.</p>
              </div>
              <div class="surface-soft rounded-[1.35rem] p-4">
                <p class="text-[0.68rem] uppercase tracking-[0.2em] text-[var(--text-soft)]">Mood</p>
                <p class="mt-2 text-sm text-[var(--text)]">Soft surfaces, sharp contrast, restrained geometry.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
