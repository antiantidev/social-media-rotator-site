---
import { sitePath } from "../lib/site.ts";
---

<footer class="px-4 py-14 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="section-surface p-6 sm:p-8 lg:p-10">
      <div class="grid gap-10 lg:grid-cols-[1.1fr_.9fr_.9fr] lg:items-start">
        <div>
          <div class="flex items-center gap-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-2xl border border-[var(--line)] bg-white text-[var(--text)] shadow-sm">
              <i class="fas fa-rss text-base"></i>
            </div>
            <div>
              <h3 class="text-lg font-semibold tracking-[-0.03em] text-[var(--text)]">
                Social Media Rotator
              </h3>
              <p class="text-sm text-[var(--text-muted)]">Monochrome, flat, and built for browser sources.</p>
            </div>
          </div>

          <p class="mt-5 max-w-md text-sm leading-7 text-[var(--text-muted)]">
            © 2026 Social Media Rotator. A small tool for streamers who want one calm link instead of a messy workflow.
          </p>

          <div class="mt-5 flex flex-wrap gap-2">
            <span class="status-pill">
              <i class="fas fa-circle text-[0.5rem] text-[var(--accent)]"></i>
              <span>Light theme</span>
            </span>
            <span class="status-pill">
              <i class="fas fa-circle text-[0.5rem] text-[var(--accent-2)]"></i>
              <span>Quick share</span>
            </span>
          </div>
        </div>

        <div>
          <h4 class="text-[0.68rem] font-medium uppercase tracking-[0.22em] text-[var(--text-soft)]">
            Support links
          </h4>
          <div class="mt-4 grid gap-3">
            <a
              href="https://paypal.me/chokernguyen"
              target="_blank"
              rel="noopener noreferrer"
              class="surface-soft inline-flex items-center gap-3 rounded-[1.25rem] px-4 py-3 transition-colors hover:bg-[var(--bg-panel-strong)]"
            >
              <span class="flex h-9 w-9 items-center justify-center rounded-full border border-[var(--line)] bg-white">
                <i class="fa-brands fa-paypal text-[var(--text)]"></i>
              </span>
              <span class="text-sm text-[var(--text)]">paypal.me/chokernguyen</span>
            </a>
            <a
              href="https://ko-fi.com/chokernguyen"
              target="_blank"
              rel="noopener noreferrer"
              class="surface-soft inline-flex items-center gap-3 rounded-[1.25rem] px-4 py-3 transition-colors hover:bg-[var(--bg-panel-strong)]"
            >
              <span class="flex h-9 w-9 items-center justify-center rounded-full border border-[var(--line)] bg-white">
                <i class="fa-solid fa-mug-hot text-[var(--text)]"></i>
              </span>
              <span class="text-sm text-[var(--text)]">ko-fi.com/chokernguyen</span>
            </a>
            <a
              href="https://zypage.com/chokernguyen"
              target="_blank"
              rel="noopener noreferrer"
              class="surface-soft inline-flex items-center gap-3 rounded-[1.25rem] px-4 py-3 transition-colors hover:bg-[var(--bg-panel-strong)]"
            >
              <span class="flex h-9 w-9 items-center justify-center rounded-full border border-[var(--line)] bg-white">
                <i class="fa-solid fa-link text-[var(--text)]"></i>
              </span>
              <span class="text-sm text-[var(--text)]">zypage.com/chokernguyen</span>
            </a>
          </div>
        </div>

        <div>
          <h4 class="text-[0.68rem] font-medium uppercase tracking-[0.22em] text-[var(--text-soft)]">
            Bank transfer
          </h4>
          <div class="surface-soft mt-4 rounded-[1.35rem] p-4">
            <p class="text-center text-xs text-[var(--text-soft)]">Scan the QR to support the project</p>
            <img
              src={sitePath("assets/bank-qr.png")}
              alt="Bank QR Code"
              class="mt-3 h-32 w-32 rounded-2xl border border-[var(--line)] object-contain"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
