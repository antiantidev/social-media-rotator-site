<section class="relative px-4 py-20 sm:py-24">
  <div class="mx-auto max-w-6xl">
    <div class="grid gap-8 lg:grid-cols-[.9fr_1.1fr] lg:items-end">
      <div>
        <span class="eyebrow">How it works</span>
        <h2 class="section-title mt-5 text-4xl sm:text-5xl lg:text-6xl">
          Three easy moves, then you’re live.
        </h2>
        <p class="hero-lead mt-5 max-w-2xl">
          The flow stays simple on purpose: set your links, generate the token,
          and drop the overlay into OBS.
        </p>
      </div>

      <div class="grid gap-3 sm:grid-cols-3">
        <div class="soft-note"><i class="fas fa-puzzle-piece text-[var(--accent)]"></i> Small steps</div>
        <div class="soft-note"><i class="fas fa-wand-magic-sparkles text-[var(--accent-2)]"></i> Quick output</div>
        <div class="soft-note"><i class="fas fa-tv text-[var(--accent-3)]"></i> Ready for OBS</div>
      </div>
    </div>

    <div class="mt-14 grid gap-5">
      <article class="step-card surface-hover overflow-hidden p-0">
        <div class="grid gap-0 lg:grid-cols-[auto_1fr]">
          <div class="flex items-center gap-4 border-b border-[var(--line)] bg-[var(--bg-panel-soft)] px-6 py-6 lg:border-b-0 lg:border-r lg:px-7">
            <span class="step-index">1</span>
            <div class="hidden h-full w-px bg-[var(--line)] lg:block"></div>
          </div>
          <div class="p-6 sm:p-7">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.22em] text-[var(--text-soft)]">
              Step one
            </p>
            <h3 class="mt-2 text-2xl font-semibold text-[var(--text)]">
              Pick the platforms you want
            </h3>
            <p class="mt-3 max-w-3xl text-base leading-7 text-[var(--text-muted)]">
              Toggle on only the networks you need, then add the exact handles or
              links you want the overlay to show.
            </p>
          </div>
        </div>
      </article>

      <article class="step-card surface-hover overflow-hidden p-0">
        <div class="grid gap-0 lg:grid-cols-[1fr_auto]">
          <div class="order-2 p-6 sm:p-7 lg:order-1">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.22em] text-[var(--text-soft)]">
              Step two
            </p>
            <h3 class="mt-2 text-2xl font-semibold text-[var(--text)]">
              Create a shareable token
            </h3>
            <p class="mt-3 max-w-3xl text-base leading-7 text-[var(--text-muted)]">
              The app stores the settings in a URL-safe token so the configuration
              moves between devices without any extra files.
            </p>
          </div>
          <div class="order-1 flex items-center gap-4 border-b border-[var(--line)] bg-white px-6 py-6 lg:border-b-0 lg:border-l lg:order-2 lg:px-7">
            <span class="step-index">2</span>
          </div>
        </div>
      </article>

      <article class="step-card surface-hover overflow-hidden p-0">
        <div class="grid gap-0 lg:grid-cols-[auto_1fr]">
          <div class="flex items-center gap-4 border-b border-[var(--line)] bg-[var(--bg-panel-soft)] px-6 py-6 lg:border-b-0 lg:border-r lg:px-7">
            <span class="step-index">3</span>
          </div>
          <div class="p-6 sm:p-7">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.22em] text-[var(--text-soft)]">
              Step three
            </p>
            <h3 class="mt-2 text-2xl font-semibold text-[var(--text)]">
              Paste it into OBS
            </h3>
            <p class="mt-3 max-w-3xl text-base leading-7 text-[var(--text-muted)]">
              Use the generated browser source URL and your rotating card is ready
              to go live.
            </p>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>
