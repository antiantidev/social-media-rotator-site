---
import { sitePath } from "../lib/site.ts";
---

<section class="px-4 py-20 sm:py-24">
  <div class="mx-auto max-w-6xl">
    <div class="section-surface overflow-hidden p-6 sm:p-8 lg:p-10">
      <div class="grid gap-10 lg:grid-cols-[1.05fr_.95fr] lg:items-center">
        <div>
          <span class="eyebrow">Ready to ship</span>
          <h2 class="section-title mt-5 text-4xl sm:text-5xl lg:text-6xl">
            Build once, then keep using the same link everywhere.
          </h2>
          <p class="hero-lead mt-5 max-w-2xl">
            Keep the setup light and precise while still looking deliberate on stream. The same token powers the settings page,
            the browser source, and the preview.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href={sitePath("settings/")} class="button-primary">
              <i class="fas fa-wand-magic-sparkles"></i>
              <span>Start configuring</span>
            </a>
            <a href={sitePath("overlay/")} class="button-secondary">
              <i class="fas fa-tv"></i>
              <span>View overlay demo</span>
            </a>
          </div>
        </div>

        <div class="grid gap-3">
          <div class="surface-soft rounded-[1.35rem] p-4">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.22em] text-[var(--text-soft)]">What you keep</p>
            <div class="mt-3 space-y-3 text-sm text-[var(--text-muted)]">
              <div class="flex items-center gap-3">
                <i class="fas fa-check text-[var(--accent)]"></i>
                <span>One token, no account, no storage layer.</span>
              </div>
              <div class="flex items-center gap-3">
                <i class="fas fa-check text-[var(--accent-2)]"></i>
                <span>Preview and overlay stay in sync as you edit.</span>
              </div>
              <div class="flex items-center gap-3">
                <i class="fas fa-check text-[var(--accent-3)]"></i>
                <span>Shareable URL that fits the way streamers already work.</span>
              </div>
            </div>
          </div>

          <div class="grid gap-3 sm:grid-cols-2">
            <div class="surface-soft rounded-[1.35rem] p-4">
              <p class="font-mono text-[0.68rem] uppercase tracking-[0.22em] text-[var(--text-soft)]">Built for</p>
              <p class="mt-2 text-sm leading-6 text-[var(--text)]">
                Twitch, YouTube, TikTok, Discord, and every small creator stack in between.
              </p>
            </div>
            <div class="surface-soft rounded-[1.35rem] p-4">
              <p class="font-mono text-[0.68rem] uppercase tracking-[0.22em] text-[var(--text-soft)]">Tone</p>
              <p class="mt-2 text-sm leading-6 text-[var(--text)]">
                Calm, legible, and intentionally designed instead of glossy and generic.
              </p>
            </div>
          </div>

          <div class="soft-note">
            <i class="fas fa-sparkles text-[var(--accent)]"></i>
            <span>Soft enough to feel friendly, sharp enough to be useful.</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
